generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String       @unique
  password    String
  firstName   String
  lastName    String
  phone       String?
  role       String       @default("user")
  isActive    Boolean      @default(true)
  applications Application[]
  notifications Notification[]  // Add this line
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Country {
  id           String     @id @default(cuid())
  name         String
  code         String     @unique
  flag         String?
  region       String?
  continent    String?
  visaRules    VisaRule[] @relation("FromCountry")
  visaRulesTo  VisaRule[] @relation("ToCountry")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model VisaRule {
  id                  String           @id @default(cuid())
  fromCountryId        String
  toCountryId        String
  fromCountry      Country          @relation("FromCountry", fields: [fromCountryId], references: [id])
  toCountry       Country          @relation("ToCountry", fields: [toCountryId], references: [id])
  visaType         String
  processingTime   String
  processingDays  Int
  price           Decimal        @db.Decimal(10, 2)
  currency       String         @default("USD")
  maxStayDays     Int
  validityDays   Int
  entryType      String
  requirements   Json
  documents      Json
  allowedActivities Json?
  additionalInfo String?      @db.Text
  isActive      Boolean       @default(true)
  sortOrder     Int          @default(0)
  applications  Application[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([fromCountryId, toCountryId, visaType])
}

model Application {
  id                 String     @id @default(cuid())
  userId            String?
  user              User?       @relation(fields: [userId], references: [id])
  visaRuleId         String
  visaRule         VisaRule    @relation(fields: [visaRuleId], references: [id])
  applicationNumber String   @unique
  status           String     @default("pending")
  formData         Json
  totalAmount     Decimal    @db.Decimal(10, 2)
  currency       String     @default("USD")
  paymentStatus  String     @default("pending")
  paymentMethod  String?
  notes           String?    @db.Text
  processedAt     DateTime?
  documents      Document[]
  createdAt      DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Document {
  id             String     @id @default(cuid())
  applicationId  String
  application    Application @relation(fields: [applicationId], references: [id])
  type          String
  originalName   String
  fileName      String
  filePath     String
  fileSize     Int
  mimeType     String
  createdAt    DateTime   @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  type        String
  title       String
  message     String
  data        Json?
  isRead      Boolean  @default(false)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}